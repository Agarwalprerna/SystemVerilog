//DATA ABSTRACTION

virtual class packet;
     bit [7:0] addr;
     //abstact method or pure virtual function 
       pure virtual function void display();   //only prototype is provided - hides the full implementation details of objects
endclass

class packet2 extends packet;

        //implement the abstract method 
        function void display();
                 $display(" value of addr =%0h",addr);   //parent properties
        endfunction
 endclass    

module tb;
      initial begin
            //virtual class cant be instantiated 
            packet2 p ;   
            p = new() ;   //child object only

            p.addr = 8'hAC;
            p.display();
end
endmodule
