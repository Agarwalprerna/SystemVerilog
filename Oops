protected qualifier- it is required to access the protected class member only by derived classs 
if we try to access it outside the class by usng object handle this leads to error

class parent;
 protected int a;

       function new( int b);
            a = b+10;
      endfunction
endclass

class child extends parent;

      function new(int b);
          super.new(b);   //parent cosntructor 
      endfunction

     function void incr_addr();
            a++;
            $display(a = %0d" ,a);
      endfunction
endclass

module tb;
 inital begin
        child C = new(10);
