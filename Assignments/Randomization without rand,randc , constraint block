2. Generate Random Numbers between MIN 100 and MAX 200 as variable
module tb;
   int num;
   int MIN  = 100;
   int MAX = 200;

  initial begin
       num = MIN +  ($urandom % (MAX -MIN));
       $display("%0d", num);
  end
endmodule

