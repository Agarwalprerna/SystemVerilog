5. Generate values between 1 and 100 using dist_uniform() 

module tb;
  int seed = 10;
  int value;

  initial begin
       repeat(10)begin
             value = $dist_uniform(seed ,1,100);  //generate numbers uniformly distributed between MIN and MAX
             $display("%0d", value);
       end
end
endmodule


