7. inline constraint without constraint block
Generate address between 100 and 200 using inline 

class packet;
   int addr;
endclass

module tb;
  packet p = new();

initial begin

    if( p.randomize(addr) with { addr >50 ; addr <100 ;})
       $display("%0d" ,p.addr);
     else
       $display("failed randomization");
end
endmodule


