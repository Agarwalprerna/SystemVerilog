interface Bus(input logic clk);
  logic rst ;
   logic [7:0] data;

 //2 modport
  modport master( output clk ,output rst , output data);
  modport slave ( input clk ,input rst , input data);

endinterface

 
module master (Bus.master bus);


  always @(posedge bus.clk) begin
        if(bus.rst)
            $display("master reset active at %0t" , $time);
         else
            $display("master data = %0d at %0t" , bus.data , $time);
 end
  
 endmodule

module slave( Bus.slave bus);
    always @(posedge bus.clk)
        $display("slave see at time = %0t data = %0d" , $time , bus.data);
endmodule


//Top 
module Top_tb;
         logic clk;
        Bus intf(clk);  //interface instantiate
     
          //Module instantiate
        master M(intf);
        slave S(intf);

    initial clk = 0;
   always #5 clk = ~clk;

  initial begin

        intf.rst = 1;
        intf.data =0;

        #10;
        intf.rst =0;

         repeat(5) begin
             @(posedge intf.clk);
                intf.data = $urandom_range(0,255);
         end
     #20;
     $finish;
 end
endmodule



