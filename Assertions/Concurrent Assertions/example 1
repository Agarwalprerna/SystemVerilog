module exmtb;
  
  logic clk =0;
  logic req, ack;

always #5 clk = ~clk;


  property p1;
     @(posedge clk) req |-> ##1 ack;   //If req is TRUE at the clock edge, then ack must become TRUE 1 clock cycle later.
  endproperty 

 A1: assert property (p1)
         $info("assertion pass");
     else
          $error("assertion fail");


initial begin
    req =0;
    ack =0;

    #10;
    req = 1;     //req asserted
    #10 ack =1;   //correct ack signal after 1 clcok cycle delay

    #10
     req = 1;    //req asserted
      ack =0;   // incorrect

    #50;
    $finish;
end

endmodule

