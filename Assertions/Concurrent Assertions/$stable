module exmtb;
  
  logic clk =0;
  logic data;

always #5 clk = ~clk;


property p1;
    @(posedge clk) $stable(data);  // data should remian stable over clock cycle

endproperty

A1: assert property(p1)
         $info("assertion Pass");
    else
         $error("assertion fail");

initial begin
  
    data = 1;   //after t=0
    #10 data = 0;  // after t=10
   #20 data = 1;   //after t=30
   #10 data = 0;   //after t = 40
    #50 $finish;
end
endmodule


