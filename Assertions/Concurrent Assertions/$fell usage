module exmtb;
  
  logic clk =0;
  logic signal;

always #5 clk = ~clk;


property p1;
    @(posedge clk) $fell(signal);
endproperty

A1: assert property(p1)
         $info("assertion Pass");
    else
         $error("assertion fail");

initial begin
  
    signal = 1;           //t =0
   #10 signal = 0;         // after t=10
   #20 signal = 1;          //after t= 30
   #10 signal = 0;             //after t=40
    #50 $finish;                  //after t=90
end
endmodule

//no Implication operator

//assertion checks trigger at every posedge clock ( 5ns ,15n ,25,35,45,55....) until $finish
//checks only signal transitioned from 1 to 0



